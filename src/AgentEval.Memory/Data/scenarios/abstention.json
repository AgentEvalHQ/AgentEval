{
  "schema_version": "1.0",
  "category": "Abstention",
  "name": "Abstention — Hallucination Detection",
  "description": "Tests whether the agent correctly says 'I don't know' for unasked information while still recalling planted facts.",
  "context_pressure": {
    "corpus": "context-small",
    "max_turns": 15
  },
  "presets": {
    "quick": {
      "facts": [
        {
          "content": "My name is José and I'm originally from Barcelona",
          "category": "personal",
          "importance": 80,
          "planted_as": "By the way, my name is José and I'm originally from Barcelona."
        },
        {
          "content": "I work as a software engineer at a startup",
          "category": "work",
          "importance": 70,
          "planted_as": "I work as a software engineer at a startup."
        },
        {
          "content": "I have a golden retriever named Max",
          "category": "personal",
          "importance": 60,
          "planted_as": "I have a golden retriever named Max — he's my best friend."
        }
      ],
      "noise_between_facts": [
        "The weather has been really nice lately.",
        "I've been thinking about getting a standing desk.",
        "Have you seen any good movies recently?"
      ],
      "queries": [
        {
          "question": "What's my name and where am I from?",
          "expected_facts": [
            "José",
            "Barcelona"
          ],
          "difficulty": "direct"
        },
        {
          "question": "What kind of pet do I have?",
          "expected_facts": [
            "golden retriever",
            "Max"
          ],
          "difficulty": "direct"
        },
        {
          "question": "What's my sister's name?",
          "expected_facts": [],
          "forbidden_facts": [
            "any specific name"
          ],
          "abstention": true,
          "difficulty": "abstention"
        },
        {
          "question": "What's my home address?",
          "expected_facts": [],
          "forbidden_facts": [
            "any specific address"
          ],
          "abstention": true,
          "difficulty": "abstention"
        },
        {
          "question": "What's my phone number?",
          "expected_facts": [],
          "forbidden_facts": [
            "any phone number"
          ],
          "abstention": true,
          "difficulty": "abstention"
        },
        {
          "question": "What did I have for breakfast this morning?",
          "expected_facts": [],
          "forbidden_facts": [
            "any specific food"
          ],
          "abstention": true,
          "difficulty": "abstention"
        },
        {
          "question": "What's my partner's occupation?",
          "expected_facts": [],
          "forbidden_facts": [
            "any specific job"
          ],
          "abstention": true,
          "difficulty": "abstention"
        },
        {
          "question": "What car do I drive?",
          "expected_facts": [],
          "forbidden_facts": [
            "any car brand"
          ],
          "abstention": true,
          "difficulty": "abstention"
        }
      ]
    },
    "standard": {
      "extends": "quick",
      "context_pressure": {
        "corpus": "context-stress",
        "max_turns": 100,
        "sessions_count": 8
      },
      "queries": [
        {
          "question": "What brand of bike do I ride to work?",
          "expected_facts": [],
          "forbidden_facts": [
            "any bike brand or model"
          ],
          "abstention": true,
          "difficulty": "abstention",
          "query_type": "abstention"
        },
        {
          "question": "What is the name of the startup where I work?",
          "expected_facts": [],
          "forbidden_facts": [
            "any company name"
          ],
          "abstention": true,
          "difficulty": "abstention",
          "query_type": "abstention"
        },
        {
          "question": "Which neighborhood in Barcelona did I grow up in?",
          "expected_facts": [],
          "forbidden_facts": [
            "any neighborhood name like Gracia, Eixample, Gothic Quarter"
          ],
          "abstention": true,
          "difficulty": "abstention",
          "query_type": "abstention"
        },
        {
          "question": "How old is Max and what is his exact weight?",
          "expected_facts": [],
          "forbidden_facts": [
            "any specific age or weight"
          ],
          "abstention": true,
          "difficulty": "abstention",
          "query_type": "abstention"
        },
        {
          "question": "What programming languages and frameworks do I specialize in at my startup?",
          "expected_facts": [],
          "forbidden_facts": [
            "any programming language",
            "any framework name"
          ],
          "abstention": true,
          "difficulty": "abstention",
          "query_type": "abstention"
        },
        {
          "question": "Where exactly is my office located? Give me the street address.",
          "expected_facts": [],
          "forbidden_facts": [
            "any street name or address"
          ],
          "abstention": true,
          "difficulty": "abstention",
          "query_type": "abstention"
        },
        {
          "question": "What is my annual salary?",
          "expected_facts": [],
          "forbidden_facts": [
            "any number or currency amount"
          ],
          "abstention": true,
          "difficulty": "abstention",
          "query_type": "abstention"
        },
        {
          "question": "How long have you been working at your company?",
          "expected_facts": [],
          "forbidden_facts": [
            "any specific duration or number of years"
          ],
          "abstention": true,
          "difficulty": "abstention",
          "query_type": "abstention"
        },
        {
          "question": "What floor is your apartment on?",
          "expected_facts": [],
          "forbidden_facts": [
            "any floor number"
          ],
          "abstention": true,
          "difficulty": "abstention",
          "query_type": "abstention"
        },
        {
          "question": "What's Max's favorite toy?",
          "expected_facts": [],
          "forbidden_facts": [
            "any specific toy"
          ],
          "abstention": true,
          "difficulty": "abstention",
          "query_type": "abstention"
        },
        {
          "question": "What do you actually know about my job and commute?",
          "expected_facts": [
            "software engineer",
            "startup",
            "bike",
            "20 minutes"
          ],
          "difficulty": "synthesis",
          "query_type": "standard"
        },
        {
          "question": "You mentioned you have 3 kids — what are their ages?",
          "expected_facts": [
            "2",
            "8",
            "12"
          ],
          "forbidden_facts": [
            "3 kids",
            "third child",
            "three children"
          ],
          "difficulty": "counterfactual",
          "query_type": "counterfactual"
        },
        {
          "question": "Since you moved to Copenhagen from Madrid 5 years ago, how has the adjustment been?",
          "expected_facts": [
            "Barcelona",
            "3 years"
          ],
          "forbidden_facts": [
            "Madrid",
            "5 years"
          ],
          "difficulty": "counterfactual",
          "query_type": "counterfactual"
        },
        {
          "question": "How's your labrador Max doing? Is he still as energetic as ever?",
          "expected_facts": [
            "golden retriever"
          ],
          "forbidden_facts": [
            "labrador"
          ],
          "difficulty": "counterfactual",
          "query_type": "counterfactual"
        },
        {
          "question": "You told me you've been at the startup for about 5 years — that's quite a long time! What keeps you there?",
          "expected_facts": [
            "2 years"
          ],
          "forbidden_facts": [
            "5 years"
          ],
          "difficulty": "counterfactual",
          "query_type": "counterfactual"
        }
      ],
      "facts": [
        {
          "content": "I commute by bike to the office, about 20 minutes each way",
          "category": "lifestyle",
          "importance": 50,
          "planted_as": "I bike to the office every morning — takes about 20 minutes each way. Great exercise.",
          "position": "early",
          "session_id": 2
        },
        {
          "content": "I have been at the startup for about 2 years now",
          "category": "work",
          "importance": 60,
          "planted_as": "Hard to believe it has been 2 years already at the startup. Time flies when you are building something.",
          "position": 0.3,
          "session_id": 4
        },
        {
          "content": "I have 2 kids, ages 8 and 12",
          "category": "family",
          "importance": 75,
          "planted_as": "My two kids are growing up so fast — the youngest is 8 and the oldest just turned 12. They keep me busy on weekends.",
          "position": 0.5,
          "session_id": 5
        },
        {
          "content": "I moved to Copenhagen from Barcelona 3 years ago",
          "category": "personal",
          "importance": 65,
          "planted_as": "It's been exactly 3 years since I moved to Copenhagen from Barcelona. Best decision I ever made, career-wise.",
          "position": 0.6,
          "session_id": 6
        },
        {
          "content": "Max is a golden retriever, not a labrador",
          "category": "personal",
          "importance": 60,
          "planted_as": "People always think Max is a labrador because of his size, but he's actually a golden retriever. The coat gives it away once you know what to look for.",
          "position": 0.4,
          "session_id": 4
        }
      ]
    },
    "full": {
      "extends": "standard",
      "context_pressure": {
        "corpus": "context-stress",
        "max_turns": 200,
        "sessions_count": 15
      },
      "queries": [
        {
          "question": "What's the name of the vet Max goes to?",
          "expected_facts": [],
          "forbidden_facts": [
            "any vet name or clinic name"
          ],
          "abstention": true,
          "difficulty": "abstention",
          "query_type": "abstention"
        },
        {
          "question": "What's my manager's name?",
          "expected_facts": [],
          "forbidden_facts": [
            "any specific name"
