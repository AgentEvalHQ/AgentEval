{
  "schema_version": "1.0",
  "category": "FactUpdateHandling",
  "name": "Fact Update Handling",
  "description": "Tests agent's ability to handle corrections — updating old facts with new ones.",
  "context_pressure": { "corpus": "context-small", "max_turns": 15 },
  "presets": {
    "quick": {
      "facts": [
        { "content": "My favorite color is blue", "category": "preference", "importance": 50, "planted_as": "My favorite color is blue." },
        { "content": "I drive a Honda Civic", "category": "personal", "importance": 60, "planted_as": "I drive a Honda Civic." }
      ],
      "noise_between_facts": [
        "I've been meaning to redecorate my apartment.",
        "The weather has been unpredictable lately."
      ],
      "queries": [
        { "question": "What's my current favorite color?", "expected_facts": ["green"], "forbidden_facts": ["blue"], "difficulty": "direct" },
        { "question": "What car do I drive now?", "expected_facts": ["Tesla"], "forbidden_facts": ["Honda"], "difficulty": "direct" }
      ]
    },
    "standard": {
      "extends": "quick",
      "context_pressure": { "corpus": "context-medium", "max_turns": 30 }
    },
    "full": {
      "extends": "standard",
      "context_pressure": { "corpus": "context-medium", "max_turns": 40 }
    }
  }
}
